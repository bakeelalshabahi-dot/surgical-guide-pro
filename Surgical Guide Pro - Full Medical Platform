// Surgical Guide Pro - Full Medical Platform (Next.js App) // This is a complete upgraded system: Auth + Dashboard + Medical Library + OSCE Bank

import { useState } from "react"; import { Card, CardContent } from "@/components/ui/card"; import { Button } from "@/components/ui/button"; import { Input } from "@/components/ui/input"; import { Stethoscope, BookOpen, Shield, User, LogIn } from "lucide-react";

export default function SurgicalGuideProApp() { const [user, setUser] = useState(null); const [page, setPage] = useState("home");

// Mock login const login = () => setUser({ name: "Dr. User", role: "surgeon" }); const logout = () => setUser(null);

// NAVIGATION const Navigation = () => ( <div className="flex justify-between items-center p-4 bg-white shadow"> <h1 className="font-bold text-blue-700 text-xl">Surgical Guide Pro</h1> <div className="space-x-3 text-sm"> <button onClick={() => setPage("home")}>Home</button> <button onClick={() => setPage("library")}>Library</button> <button onClick={() => setPage("osce")}>OSCE</button> <button onClick={() => setPage("dashboard")}>Dashboard</button> </div> <div> {!user ? ( <Button onClick={login}><LogIn className="w-4 h-4 mr-1" /> Login</Button> ) : ( <div className="flex gap-2 items-center"> <User className="w-4 h-4" /> <span className="text-sm">{user.name}</span> <Button variant="outline" onClick={logout}>Logout</Button> </div> )} </div> </div> );

// HOME const Home = () => ( <div className="p-10 text-center"> <h2 className="text-3xl font-bold mb-4">Advanced Surgical Learning Platform</h2> <p className="text-gray-600 mb-6"> A complete system for surgeons, residents, and medical students. </p> <div className="grid md:grid-cols-3 gap-6"> <Card><CardContent className="p-6"><Stethoscope /> Clinical Cases</CardContent></Card> <Card><CardContent className="p-6"><BookOpen /> Surgical Library</CardContent></Card> <Card><CardContent className="p-6"><Shield /> Evidence-Based Practice</CardContent></Card> </div> </div> );

// LIBRARY const Library = () => ( <div className="p-8"> <h2 className="text-2xl font-bold mb-4">Surgical Library</h2> <Card><CardContent className="p-4">Appendectomy - Step by step guide</CardContent></Card> <Card><CardContent className="p-4">Perforated Ulcer - Graham Patch Technique</CardContent></Card> </div> );

// OSCE const OSCE = () => ( <div className="p-8"> <h2 className="text-2xl font-bold mb-4">OSCE Bank</h2> <Card><CardContent className="p-4">Acute Abdomen - Station</CardContent></Card> <Card><CardContent className="p-4">Trauma Assessment (ABCDE)</CardContent></Card> </div> );

// DASHBOARD const Dashboard = () => ( <div className="p-8"> <h2 className="text-2xl font-bold mb-4">Admin Dashboard</h2> {!user ? ( <p>Please login to access dashboard</p> ) : ( <div> <Card><CardContent className="p-4">Add New Case</CardContent></Card> <Card><CardContent className="p-4">Upload Surgical Article</CardContent></Card> <Card><CardContent className="p-4">Manage Users</CardContent></Card> </div> )} </div> );

// PAGE RENDER const renderPage = () => { switch (page) { case "library": return <Library />; case "osce": return <OSCE />; case "dashboard": return <Dashboard />; default: return <Home />; } };

return ( <div className="min-h-screen bg-gray-50"> <Navigation /> {renderPage()} <footer className="text-center p-4 text-sm text-gray-500"> © {new Date().getFullYear()} Surgical Guide Pro - Medical Platform </footer> </div> ); }
